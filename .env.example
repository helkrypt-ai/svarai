# =====================================================================
# SvarAI — Environment Variables
# Copy to .env.local and fill in your values
# =====================================================================

# App URL (used for Stripe redirect URLs, widget base URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================================
# Supabase (EU West / Frankfurt region for GDPR)
# https://supabase.com → Settings → API
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================================
# Anthropic Claude API
# https://console.anthropic.com/settings/keys
# =====================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =====================================================================
# Stripe (NOK payments)
# https://dashboard.stripe.com/apikeys
# Create 3 subscription products at 199/399/799 NOK/mnd and copy Price IDs
# =====================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# =====================================================================
# Resend (transactional email)
# https://resend.com/api-keys
# =====================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=SvarAI
